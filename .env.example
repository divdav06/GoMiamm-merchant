# Merchant portal env vars. Copy to .env.local for local dev; configure
# the same names in Cloudflare Pages → Settings → Environment Variables
# for preview + production deploys.
#
# NEXT_PUBLIC_* are inlined into the client bundle by Next.js, so they
# must be the anon (public) Supabase key — never the service role.
# Mirror of EXPO_PUBLIC_SUPABASE_URL / EXPO_PUBLIC_SUPABASE_ANON_KEY in
# the customer-app + driver-app .env files.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
