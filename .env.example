# Merchant portal env vars. Copy to .env.local for local dev; configure
# the same names in Cloudflare Pages → Settings → Environment Variables
# for preview + production deploys.
#
# NEXT_PUBLIC_* are inlined into the client bundle by Next.js, so they
# must be the anon (public) Supabase key — never the service role.
# Mirror of EXPO_PUBLIC_SUPABASE_URL / EXPO_PUBLIC_SUPABASE_ANON_KEY in
# the customer-app + driver-app .env files.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only — used by Server Actions for menu_items mutations and
# menu-photos uploads. NEVER prefix with NEXT_PUBLIC_; if leaked into
# the client bundle it'd give anyone full DB write.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Same Stripe secret key the customer-app + driver-app edge functions
# use (Deno.env.get("STRIPE_SECRET_KEY")). Server-only — Stripe Connect
# onboarding and account-status queries happen in Server Actions.
STRIPE_SECRET_KEY=your-stripe-secret-key

# Used as the redirect target for Stripe Connect onboarding (refresh /
# return URLs). Plain http://localhost:3000 in dev; https://merchant.
# gomiamm.com in production.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
